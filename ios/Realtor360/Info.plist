    <array>
        <string>_http._tcp</string>
    </array>
    <key>NSCameraUsageDescription</key>
    <string>We need camera access to capture 360° photos for your virtual tour.</string>
    <key>NSMotionUsageDescription</key>
    <string>We need motion sensor access to guide you through the 360° capture process.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>We need photo library access to import 360° photos for your virtual tour.</string>
